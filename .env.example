# Automatically set by docker-compose — override only if running outside Docker
DATABASE_URL=postgresql://alphatrix:alphatrix@localhost:5432/alphatrix
REDIS_URL=redis://localhost:6379

# Wallet encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=your-64-char-hex-string-here

# Privy auth (frontend-owned authentication, backend verifies access tokens)
PRIVY_APP_ID=
PRIVY_VERIFICATION_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PRIVY_JWT_ISSUER=privy.io

# App domain
APP_DOMAIN=localhost
APP_URL=http://localhost:8000

# Bayse Markets
BAYSE_BASE_URL=https://relay.bayse.markets
BAYSE_WS_URL=wss://socket.bayse.markets
BAYSE_PUBLIC_KEY=pk_live_
BAYSE_SECRET_KEY=sk_live_

# Polymarket
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_PRIVATE_KEY=0x
POLYMARKET_CHAIN_ID=137

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PROGRAM_ID=
